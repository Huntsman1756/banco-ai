# Banco AI - Production Environment Variables
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.

# ─── Application ──────────────────────────────────────────────
NODE_ENV=production
PORT=3000
LOG_LEVEL=info

# ─── Database ─────────────────────────────────────────────────
# For NaN Cloud or any managed PostgreSQL:
POSTGRES_USER=banco
POSTGRES_PASSWORD=<CHANGE_ME_USE_STRONG_PASSWORD>
POSTGRES_DB=banco_ai
DATABASE_URL=postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@<DB_HOST>:5432/${POSTGRES_DB}

# ─── Session & Auth ───────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=<CHANGE_ME_USE_RANDOM_HEX>
ADMIN_REVIEW_TOKEN=<CHANGE_ME_USE_STRONG_TOKEN>

# ─── CORS ─────────────────────────────────────────────────────
# Comma-separated list of allowed origins (no trailing slash)
ALLOWED_ORIGINS=https://banco-ai.nan.cloud

# ─── LLM / NAN ───────────────────────────────────────────────
OPENAI_BASE_URL=https://api.nan.builders/v1
NAN_BASE_URL=https://api.nan.builders/v1
NAN_MODEL=qwen3.6
NAN_REVIEW_MODEL=gemma4
NAN_MAX_RPM=60
NAN_MAX_CONCURRENT=3
NAN_MODEL_MAX_TPM=1500000
NAN_MAX_QUEUE_SIZE=50
NAN_QUEUE_TIMEOUT_MS=15000
OPENAI_API_KEY=<CHANGE_ME>
NAN_API_KEY=<CHANGE_ME>
NAN_TIMEOUT_MS=30000
NAN_LLM_RETRIES=2

# ─── Scraper ──────────────────────────────────────────────────
SCHEDULER_ENABLED=true
SCRAPER_USER_AGENT=BancoAI/1.3 (+contact@example.com)
SCRAPER_WEEKLY_HOUR=3
SCRAPER_WEEKLY_MINUTE=15
SCRAPER_STARTUP_RUN=false

# ─── Redis (optional - for future caching) ───────────────────
REDIS_URL=

# ─── Review ───────────────────────────────────────────────────
REVIEW_SMOKE_MAX_SOURCES=
